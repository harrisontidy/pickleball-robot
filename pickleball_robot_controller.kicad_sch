		(exclude_from_sim no)
		(at 25 81 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "ac7b31a3-4721-4f30-b0b1-4334ab0176a5")
	)
	(text "5V CONTROL BUCK (ESP32 + LOGIC ONLY)"
		(exclude_from_sim no)
		(at 125 16 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "6bb7ad75-fd6c-4b11-954a-b70e05626123")
	)
	(text "ESP32-PICO-KIT V4.1 SOCKETS"
		(exclude_from_sim no)
		(at 20 98 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "cacdcf29-f64f-49ff-ab67-14a5aec83445")
	)
	(text "DIP-34 W17.78mm is a provisional carrier pad pattern; verify against the real board before ordering."
		(exclude_from_sim no)
		(at 25 180 0.0000)
		(effects
			(font
				(size 1.2 1.2)
			)
		)
		(uuid "443c4189-daa3-4ec7-bb66-e7e1f5e52907")
	)
	(text "RASPBERRY PI UART / CONTROL"
		(exclude_from_sim no)
		(at 125 98 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "148f752b-ac59-4262-8e09-15838b4e801e")
	)
	(text "UART is 3.3V: Pi GPIO14 TX -> ESP RX0; ESP TX0 -> Pi GPIO15 RX."
		(exclude_from_sim no)
		(at 126 158 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "533ead1f-a907-49a1-a05d-231ed99c24e1")
	)
	(text "Do not connect Pi/ESP UART while Micro-USB serial is actively driving RX0/TX0."
		(exclude_from_sim no)
		(at 126 163 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "bf7afa96-c16a-457f-a3b6-7477e24f6052")
	)
	(text "LEFT MOTOR DRIVER"
		(exclude_from_sim no)
		(at 20 198 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "89f4d0fb-bc64-43a7-bf56-1360f5dc2224")
	)
	(text "RIGHT MOTOR DRIVER"
		(exclude_from_sim no)
		(at 135 198 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "2a535478-c9b8-40ca-b8c6-3376c63b9615")
	)
	(text "WHEEL ENCODERS (3.3V)"
		(exclude_from_sim no)
		(at 248 16 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "1cd37983-f7f3-4f75-b87a-826d1d4746a5")
	)
	(text "Encoder inputs include pull-ups, RC filtering, and Schmitt buffers."
		(exclude_from_sim no)
		(at 247 126 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "44862f19-a7fa-4ff9-a59a-fdece2fd8a37")
	)
	(text "SAFETY / REVIEW NOTES"
		(exclude_from_sim no)
		(at 248 130 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "0b341fc6-b27b-4e9f-a15a-46ad2cbd1bdf")
	)
	(text "1. VNH5019 exposed pads need reflow, thermal vias, and large copper pours."
		(exclude_from_sim no)
		(at 248 140 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "68cd8278-c07a-4280-879c-0b72f05febf9")
	)
	(text "2. Verify actual motor stall current before ordering production PCB."
		(exclude_from_sim no)
		(at 248 146 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "b4ee1554-a0c4-4c5f-a78d-fe1c08b0c44d")
	)
	(text "3. Pi power is NOT made by U1. Feed J8 from a separate regulated 5V/5A supply."
		(exclude_from_sim no)
		(at 248 152 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "83c21ef8-27b0-4d3b-a781-c38f95b6932c")
	)
	(text "4. Never power ESP32 from USB and EXT_5V simultaneously."
		(exclude_from_sim no)
		(at 248 158 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "d962056d-769c-41ef-ae8e-8a711f6a6663")
	)
	(text "5. External fuse and latching E-stop are mandatory."
		(exclude_from_sim no)
		(at 248 164 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "3296e798-d698-432d-b767-de7f55302c13")
	)
	(text "3-DOF ARM SERVO CONTROL"
		(exclude_from_sim no)
		(at 248 178 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "db4362c5-f7a2-4bd2-9aa3-4e86ae27372d")
	)
