		(uuid "864a606c-f1ac-409f-8d6e-3b06923b4b8b")
	)
	(text "3. Pi power is NOT made by U1. Feed J8 from a separate regulated 5V/5A supply."
		(exclude_from_sim no)
		(at 248 152 0.0000)
		(effects
