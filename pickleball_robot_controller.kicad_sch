				(size 1.1 1.1)
			)
		)
		(uuid "b8edbe14-6672-49eb-afc7-504dd5b20c49")
	)
	(text "3. Pi power is NOT made by U1. Feed J8 from a separate regulated 5V/5A supply."
		(exclude_from_sim no)
		(at 248 152 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "5d57ea91-3352-4478-9072-ea5b2d602cd5")
	)
	(text "4. Never power ESP32 from USB and EXT_5V simultaneously."
