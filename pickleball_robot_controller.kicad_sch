		(uuid "7b56c193-c921-494b-bbd8-88a261c6410e")
	)
	(text "1. VNH5019 exposed pads need reflow, thermal vias, and large copper pours."
		(exclude_from_sim no)
		(at 248 140 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "4859349c-9830-4c94-9966-5f22d0126587")
	)
	(text "2. Verify actual motor stall current before ordering production PCB."
		(exclude_from_sim no)
		(at 248 146 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "54b2dc2a-517c-41e3-ab8d-25b447308d4c")
	)
	(text "3. Pi power is NOT made by U1. Feed J8 from a separate regulated 5V/5A supply."
		(exclude_from_sim no)
		(at 248 152 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "2b9de764-66c6-4432-9537-6a45df7ff90b")
	)
	(text "4. Never power ESP32 from USB and EXT_5V simultaneously."
		(exclude_from_sim no)
		(at 248 158 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "5007731f-22df-4f35-8817-2dee75d29fd3")
	)
	(text "5. External fuse and latching E-stop are mandatory."
		(exclude_from_sim no)
		(at 248 164 0.0000)
		(effects
			(font
				(size 1.1 1.1)
			)
		)
		(uuid "a463bacf-8a3f-44e5-bf2e-cf447cd2e500")
	)
