	)
	(text "LM2678T-5.0 makes the shared 5 V rail on this PCB. It powers the ESP32, all three servos, and Pi output J12."
		(exclude_from_sim no)
		(at 195 160 0.0000)
		(effects
			(font
				(size 1.25 1.25)
			)
		)
		(uuid "23ca2c7b-ca46-4082-aef4-50317694099a")
	)
	(text "J12: two +5 V contacts to Pi pins 2+4; two GND contacts to two Pi ground pins."
		(exclude_from_sim no)
		(at 195 170 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "999b801a-c46a-4588-9f71-d8ddda602c6a")
	)
	(text "ONE DUAL H-BRIDGE"
		(exclude_from_sim no)
		(at 340 20 0.0000)
		(effects
			(font
				(size 2 2)
				(bold yes)
			)
		)
		(uuid "699d09ff-d6c4-41f2-8e07-1d9f082bc415")
	)
	(text "DRV8848 contains both H-bridges, flyback paths, thermal shutdown, undervoltage and overcurrent protection."
		(exclude_from_sim no)
		(at 205 165 0.0000)
		(effects
			(font
				(size 1.25 1.25)
			)
		)
		(uuid "1fbfc275-e27e-4397-838f-93315b2dfbb9")
	)
	(text "MOTOR CABLE ORDER: 1 red motor; 2 black encoder GND; 3 yellow encoder A; 4 green encoder B; 5 blue encoder 3.3 V; 6 white motor."
		(exclude_from_sim no)
		(at 205 265 0.0000)
		(effects
			(font
				(size 1.25 1.25)
			)
		)
		(uuid "6bfcbab4-80c8-445e-b458-dc02700c7466")
	)
