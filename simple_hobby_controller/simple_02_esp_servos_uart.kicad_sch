		(uuid "652b636b-ac26-419a-b8a4-b1fb9d002cb8")
	)
	(text "Motor encoder outputs are assumed 3.3 V because their blue supply wire is powered from 3.3 V."
		(exclude_from_sim no)
		(at 125 285 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "78b0f045-d8a4-427a-a0a8-035b02ee4888")
	)
	(text "RASPBERRY PI 3.3 V UART"
		(exclude_from_sim no)
		(at 300 205 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "fb1ac8ef-ced6-49bb-92b8-66d4bd192245")
	)
	(text "J11: 1 GND; 2 Pi TX -> ESP GPIO18 RX; 3 ESP GPIO19 TX -> Pi RX; 4 is 3.3 V reference only."
		(exclude_from_sim no)
		(at 245 275 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "ec208312-e841-4b6e-ac1d-ec5eb7f83c05")
	)
	(text "J11 is UART only. Raspberry Pi power comes from the shared +5 V rail through high-current connector J12 on page 2."
