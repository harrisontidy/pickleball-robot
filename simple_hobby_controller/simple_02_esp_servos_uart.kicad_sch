				(bold yes)
			)
		)
		(uuid "3bac00d6-d3ca-4b6e-9af7-b0065a7ca342")
	)
	(text "Servo headers: pin 1 GND, pin 2 regulated +5 V, pin 3 separate PWM. Each servo moves independently."
		(exclude_from_sim no)
		(at 205 165 0.0000)
		(effects
			(font
				(size 1.25 1.25)
			)
		)
		(uuid "147184dd-7ec4-4fc2-9fc3-07b5d02be513")
