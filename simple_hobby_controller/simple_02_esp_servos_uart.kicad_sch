	(text "THREE INDEPENDENT 5 V SERVOS"
		(exclude_from_sim no)
		(at 245 20 0.0000)
		(effects
			(font
				(size 2 2)
				(bold yes)
			)
		)
		(uuid "e02ab0e8-c5b9-4001-9e34-5cac038d2e27")
	)
	(text "Servo headers: pin 1 GND, pin 2 regulated +5 V, pin 3 separate PWM. Each servo moves independently."
		(exclude_from_sim no)
		(at 205 165 0.0000)
		(effects
			(font
				(size 1.25 1.25)
			)
		)
		(uuid "0c2ae827-1385-4ccb-b2e9-8840ac3b0e06")
	)
	(text "ENCODER INPUTS"
		(exclude_from_sim no)
		(at 70 205 0.0000)
		(effects
			(font
