				(bold yes)
			)
		)
		(uuid "b978ecd0-fad6-4e4f-bd42-eb3dd0abbd2c")
	)
	(text "Motor encoder outputs are assumed 3.3 V because their blue supply wire is powered from 3.3 V."
		(exclude_from_sim no)
		(at 125 285 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "c4527198-1f97-4516-abb8-fdd19452d24a")
	)
	(text "RASPBERRY PI 3.3 V UART"
		(exclude_from_sim no)
		(at 300 205 0.0000)
		(effects
			(font
				(size 1.8 1.8)
				(bold yes)
			)
		)
		(uuid "29136268-a33c-447e-8a59-2190a82f4063")
	)
	(text "J11: 1 GND; 2 Pi TX -> ESP GPIO18 RX; 3 ESP GPIO19 TX -> Pi RX; 4 is 3.3 V reference only."
		(exclude_from_sim no)
		(at 245 275 0.0000)
		(effects
			(font
				(size 1.15 1.15)
			)
		)
		(uuid "9c7c95da-e239-4cd2-9d9e-a3180d23f1c9")
	)
	(text "DO NOT power the Raspberry Pi from J11. Power the Pi from its own proper 5 V supply/USB-C regulator."
